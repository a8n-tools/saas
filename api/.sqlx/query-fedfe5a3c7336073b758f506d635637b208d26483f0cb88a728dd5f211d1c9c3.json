  "query": "\n            SELECT id, sid, user_id, created_at, last_active_at, expires_at,\n                   revoked_at, user_agent,\n                   ip::TEXT as \"ip: String\",\n                   acr, amr\n            FROM op_sessions\n            WHERE sid = $1\n              AND revoked_at IS NULL\n              AND expires_at > NOW()\n            ",
