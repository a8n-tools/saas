  "query": "\n            INSERT INTO op_sessions\n                (id, sid, user_id, created_at, last_active_at, expires_at,\n                 user_agent, ip, acr, amr)\n            VALUES\n                (gen_random_uuid(), $1, $2, NOW(), NOW(), $3, $4, $5::inet, $6, $7)\n            RETURNING\n                id, sid, user_id, created_at, last_active_at, expires_at,\n                revoked_at, user_agent,\n                ip::TEXT as \"ip: String\",\n                acr, amr\n            ",
