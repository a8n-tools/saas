# Development Environment Defaults
# This file is auto-copied to .env by `just dev` if .env doesn't exist.
# Override values in .env as needed — .env is gitignored.

# =============================================================================
# Database (shared by postgres + api services)
# =============================================================================
POSTGRES_PASSWORD=devpassword

# =============================================================================
# OCI Registry Proxy (optional — leave commented to keep feature disabled)
# =============================================================================
# OCI_REGISTRY_ENABLED=true
# FORGEJO_BASE_URL=https://forgejo.example.com
# FORGEJO_API_TOKEN=your-forgejo-token
# OCI_REGISTRY_SERVICE=${USER}-registry.a8n.run

# =============================================================================
# Production — Docker image versions
# =============================================================================
# API_VERSION=latest
# FRONTEND_VERSION=latest
